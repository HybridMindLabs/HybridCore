# Build output belongs to whichever machine produced it. The manifest used to
# be committed while the hashed assets it names were not, so every deploy that
# ran a build collided with the tracked copy — and a manifest pointing at files
# that are not there fails quietly instead of loudly.
/public/build/*
/public/fonts-manifest.dev.json
/public/hot
/public/storage
/public/extensions

# Third-party / in-development extensions live in their own repos.
# The core only ships the reference demo + the SDK docs.
/extensions/*
!/extensions/.gitkeep
!/extensions/BUILDING_EXTENSIONS.md
!/extensions/hybridcore
/extensions/hybridcore/*
!/extensions/hybridcore/demo
/storage/*.key
/storage/app/releases
/storage/app/extension-builds
/storage/app/extension-imports
/storage/pail
/test-results
/playwright-report
/vendor
_ide_helper.php
Homestead.json
Homestead.yaml
Thumbs.db
.mcp.json
