APP_NAME=HybridCore
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://hybridcore.ddev.site
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Reverse proxies (Cloudflare, load balancers, nginx) whose forwarded headers
# are trusted. "*" trusts any proxy and is right for the common setups. Narrow
# it to a comma-separated list of proxy IPs if your origin is reachable
# directly, since a trusted proxy may declare the visitor's IP.
TRUSTED_PROXIES=*

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hybridcore
DB_USERNAME=root
DB_PASSWORD=

# Pre-install defaults use file/sync so the installer boots before a database
# is configured. After installing you can switch to database/redis drivers for
# production (Admin -> Settings, or edit .env).
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=hybridcore_

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@hybridcore.dev"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Laravel Pulse (monitoring) — data is aggregated and auto-trimmed
PULSE_ENABLED=true
PULSE_STORAGE_KEEP="7 days"

# Scout search (database = no external service; meilisearch/typesense for scale)
SCOUT_DRIVER=database
