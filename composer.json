{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "hybridcore/platform",
    "type": "project",
    "description": "HybridCore — a modular self-hosted platform for gaming communities.",
    "keywords": ["hybridcore", "gaming", "community", "laravel", "self-hosted", "game-servers"],
    "license": "proprietary",
    "homepage": "https://github.com/HybridMindLabs/HybridCore",
    "authors": [
        {
            "name": "HybridMind Labs",
            "homepage": "https://github.com/HybridMindLabs"
        }
    ],
    "support": {
        "issues": "https://github.com/HybridMindLabs/HybridCore/issues",
        "source": "https://github.com/HybridMindLabs/HybridCore"
    },
    "require": {
        "php": "^8.3",
        "austinb/gameq": "^3.1",
        "bacon/bacon-qr-code": "^3.1",
        "inertiajs/inertia-laravel": "^3.1",
        "intervention/image": "^3.0",
        "laravel/framework": "^13.8",
        "laravel/horizon": "^5.47",
        "laravel/pennant": "^1.24",
        "laravel/pulse": "^1.7",
        "laravel/reverb": "^1.10",
        "laravel/sanctum": "^4.3",
        "laravel/scout": "^11.3",
        "laravel/socialite": "^5.28",
        "laravel/tinker": "^3.0",
        "league/commonmark": "^2.8",
        "pragmarx/google2fa-laravel": "^3.0",
        "socialiteproviders/discord": "^4.2",
        "socialiteproviders/steam": "^4.3",
        "tightenco/ziggy": "^2.6",
        "torann/geoip": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi @no_additional_args",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php scripts/patch-vendors.php"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
